# Copy to .env.local for local development
# Run: cp .env.example .env.local

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Clerk — get from https://dashboard.clerk.com
# Disable "Enable sign-up" in Clerk settings for invite-only access.
# Mark admin users: Clerk Dashboard → User → publicMetadata → { "role": "admin" }
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/portal

# Neon Postgres — get from https://console.neon.tech
# Run once: psql $DATABASE_URL -f scripts/migrate.sql
DATABASE_URL=postgresql://...

# S3-compatible storage (Cloudflare R2, AWS S3, etc.)
# For R2: endpoint = https://<account-id>.r2.cloudflarestorage.com
# For AWS S3: leave STORAGE_ENDPOINT empty, set STORAGE_REGION to your region
STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=...
STORAGE_SECRET_ACCESS_KEY=...
STORAGE_BUCKET_NAME=verticality-deliverables
STORAGE_REGION=auto

# Seed script (optional) — Clerk user IDs for test accounts
SEED_CLIENT_1_CLERK_ID=user_...
SEED_CLIENT_2_CLERK_ID=user_...
